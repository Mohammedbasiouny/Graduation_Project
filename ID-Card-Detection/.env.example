# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3030,http://127.0.0.1:3030
MAX_UPLOAD_SIZE=53687091200

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HEALTH_CHECK_INTERVAL=30

# -----------------------------------------------------------------------------
# Worker / queues
# -----------------------------------------------------------------------------
WORD_GENERATION_QUEUE=word_generation_jobs
WORKER_MAX_WORKERS=4
STUDENT_QUEUE_MAX_SIZE=8
TASK_HEARTBEAT_INTERVAL=15
TASK_STALE_TIMEOUT=60
TASK_MONITOR_INTERVAL=60

# -----------------------------------------------------------------------------
# Storage and runtime paths
# Relative paths are resolved from the repository root. Absolute paths are used
# as-is. On Windows, prefer paths such as C:\id-card-detection\outputs.
# -----------------------------------------------------------------------------
OUTPUTS_DIR=./outputs
TEMP_DIR=/tmp
LOGS_DIR=./logs

# -----------------------------------------------------------------------------
# Cleanup service
# -----------------------------------------------------------------------------
OUTPUT_RETENTION_DAYS=7
CLEANUP_INTERVAL_SECONDS=3600

# -----------------------------------------------------------------------------
# Image processing / model runtime
# -----------------------------------------------------------------------------
MODEL_PATH=./models/detect_id_card.pt
TEMPLATE_PATH=./images/sift_template.jpg
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
YOLO_CONFIDENCE=0.8
YOLO_IMAGE_SIZE=640
OPENCV_NUM_THREADS=4

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------
WEBSOCKET_PUBSUB_TIMEOUT_SECONDS=1.0

# -----------------------------------------------------------------------------
# Development only
# -----------------------------------------------------------------------------
ENABLE_DEV_RESET=false

# -----------------------------------------------------------------------------
# Reserved for future integrations. The current codebase does not use a database,
# JWT/auth secret, or external AI provider key.
# -----------------------------------------------------------------------------
# DATABASE_URL=
# SECRET_KEY=
# AI_API_KEY=
