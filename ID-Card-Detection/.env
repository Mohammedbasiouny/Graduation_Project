# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3030,http://frontend:3030,http://localhost:3000,http://backend:3000

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HEALTH_CHECK_INTERVAL=30

# Worker / Queue Configuration
WORD_GENERATION_QUEUE=word_generation_jobs
WORKER_MAX_WORKERS=4
STUDENT_QUEUE_MAX_SIZE=8
TASK_HEARTBEAT_INTERVAL=15
TASK_STALE_TIMEOUT=60
TASK_MONITOR_INTERVAL=60

# Storage and Runtime Paths
OUTPUTS_DIR=./outputs
TEMP_DIR=/tmp
LOGS_DIR=./logs

# Cleanup Service
OUTPUT_RETENTION_DAYS=7
CLEANUP_INTERVAL_SECONDS=3600

# Image Processing / Model Runtime
MODEL_PATH=./models/detect_id_card.pt
TEMPLATE_PATH=./images/sift_template.jpg
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
YOLO_CONFIDENCE=0.8
YOLO_IMAGE_SIZE=640
OPENCV_NUM_THREADS=4
