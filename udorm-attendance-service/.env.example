# ================================
# Server
# ================================
APP_HOST=0.0.0.0
APP_PORT=8001

# ================================
# Database — must match udorm-backend
# ================================
DATABASE_URL=postgresql://username:password@localhost:5432/udorm_db

# ================================
# Redis
# ================================
REDIS_URL=redis://localhost:6379/0          # Redis connection string
REDIS_QUEUE_KEY=attendance_queue            # Redis list key used as attendance event queue
REDIS_LOGGED_KEY_PREFIX=logged              # Prefix for Redis sets tracking already-logged students per day
                                            # Final key format: logged:YYYY-MM-DD


# ================================
# CORS — React frontend URL
# ================================
ALLOWED_ORIGINS=http://localhost:3030       # Comma-separated for multiple origins

# ================================
# NestJs Backend URL
# ================================
NESTJS_SERVICE_URL=http://localhost:3000
INTERNAL_API_KEY=same-secret-string-as-nestjs

# ================================
# InsightFace Model
# ================================
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_CTX_ID=-1                # -1 = CPU, 0 = first GPU (CUDA)

# ================================
# Face Detection
# ================================
DETECTION_THRESHOLD=0.5              # Minimum confidence to consider a detected face valid
MAX_FACES_PER_FRAME=5               # Maximum faces to process in a single frame

# ================================
# Face Recognition
# ================================
RECOGNITION_THRESHOLD=0.30           # Cosine distance threshold — lower = stricter match

# ================================
# Photo Validation
# ================================
EXPECTED_ASPECT_RATIO_W=4            # Expected photo width ratio
EXPECTED_ASPECT_RATIO_H=6            # Expected photo height ratio
ASPECT_RATIO_TOLERANCE=0.1           # Allowed deviation from exact 4:6 ratio
MIN_BACKGROUND_BRIGHTNESS=180        # Minimum brightness value (0-255) for white background check

# ================================
# Attendance Consumer
# ================================
CONSUMER_BATCH_SIZE=50                      # Max records collected per batch before inserting to DB
CONSUMER_BATCH_WINDOW_MS=1000               # Time window in ms to collect events before batch insert