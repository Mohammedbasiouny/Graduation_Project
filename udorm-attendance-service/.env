# API Configuration
APP_HOST=0.0.0.0
APP_PORT=8001

# Database Configuration
DATABASE_URL=postgresql://postgres:123456@postgres:5432/udorm

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3030,http://frontend:3030,http://localhost:3000,http://backend:3000

# InsightFace Model Configuration
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_CTX_ID=-1

# Face Detection Settings
DETECTION_THRESHOLD=0.5
MAX_FACES_PER_FRAME=5

# Face Recognition Settings
RECOGNITION_THRESHOLD=0.3

# ID Card Aspect Ratio Settings
EXPECTED_ASPECT_RATIO_W=4
EXPECTED_ASPECT_RATIO_H=6
ASPECT_RATIO_TOLERANCE=0.05
MIN_BACKGROUND_BRIGHTNESS=180
