<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Your OTP Code</title>
    <!-- Cairo font -->
    <link
      href='https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap'
      rel='stylesheet'
    />
    <style>
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        padding: 0;
        font-family: 'Cairo', Arial, sans-serif;
        background-color: #f4f4f9;
        color: #272727;
        direction: ltr;
      }

      .container {
        height: fit-content;
        max-width: 32rem;
        margin: 2rem auto;
        padding: 2rem;
        background-color: #ffffff;
        border-radius: 0.75rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        text-align: center;
      }

      h1 {
        font-size: 1.875rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #27285d;
      }

      p {
        margin-bottom: 1.5rem;
        line-height: 1.5;
        color: #272727;
      }

      .otp-code {
        display: inline-block;
        font-size: 1.5rem;
        font-weight: 700;
        color: #b38e19;
        background-color: #f1f1f1;
        padding: 1rem 1.5rem;
        border-radius: 0.5rem;
        letter-spacing: 0.2rem;
        margin-bottom: 1.5rem;
      }

      .footer {
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: #718096;
        text-align: center;
      }

      .footer a {
        color: #27285d;
        text-decoration: none;
        font-weight: 600;
      }

      .footer a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <h1>Helwan University Cities</h1>
      <p>Thank you for signing up. Please use the OTP code below to verify your
        account. This code will expire in 30 minutes for your security.</p>
      <div class='otp-code'>
        {{otp}}
      </div>
      <p>If you did not request this code, no further action is required.</p>
      <div class='footer'>
        <p>Thank you,<br />The
          <strong>Helwan University Cities</strong>
          Team</p>
        <p>Need help?
          <a href='https://helwan.edu.eg/support'>Contact our support team</a>.</p>
      </div>
    </div>
  </body>
</html>